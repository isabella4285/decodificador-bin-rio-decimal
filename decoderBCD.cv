//codigo em verilog
module decoderBCD(input A3, A2, A1, A0, output b, a, f, g, e, d, c);
	assign a = A1 || A3 || A2 ~^ A0;
	assign b = !A2 || A1 ~^ A0;
	assign c = A3 || A2 || !A1 || A0;
	assign d = A3 || A1 && !A0 || !A2 && !A0 || !A2 && A1 || A2 && !A1 && A0;
	assign e = A1 && !A0 || !A2 && !A0;
	assign f = A3 || !A1 && !A0 || A2 && !A1 || A2 && !A0;
	assign g = A3 || A1 && !A0 || A2 ^ A1;

endmodule
